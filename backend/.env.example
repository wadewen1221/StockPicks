# 智能A股投资助手 V2 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Cookie密钥 - 必须设置，用于安全cookie加密
COOKIE_SECRET=your-secure-random-secret-here

# 允许的来源 - 生产环境请配置具体域名，用逗号分隔
# 示例: ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=*

# 调试模式 - 生产环境设为False
DEBUG=False

# API端口（可选，默认5001）
PORT=5001
